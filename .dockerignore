# Plan 4 build context trim. KEEPS data/seed/ — Tier 3 fallbacks ship in the image.
.git
.gitignore
.venv
venv
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.ruff_cache/
htmlcov/
.coverage
