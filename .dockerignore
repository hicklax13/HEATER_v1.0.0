# Plan 4 build context trim. KEEPS data/seed/ — Tier 3 fallbacks ship in the image.
.git
.gitignore
.venv
venv
.claude/
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.ruff_cache/
htmlcov/
.coverage
# Everything under data/ lives on the Railway volume at runtime (the SQLite DB +
# WAL/SHM, any *.db.backup-* snapshots, data/backups/, the Yahoo token, logs).
# Exclude the whole dir, then re-include ONLY data/seed/ whose Tier 3 fallbacks
# (catcher_framing, umpire_tendencies, park_factors) must ship in the image.
# Mirrors .gitignore's allow-list shape so new data/ files can't silently leak in.
data/*
!data/seed/
!data/seed/**
.env
*.log
# Not needed in the runtime image.
docs/
tests/
.github/
